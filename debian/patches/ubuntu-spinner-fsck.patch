+                                 (ply_event_handler_t)
+                                 ply_boot_server_on_hangup,
+                                 server);
         ply_event_loop_watch_for_exit (loop, (ply_event_loop_exit_handler_t)
                                        ply_boot_server_detach_from_event_loop,
                                        server);
