+                        for (node = ply_list_get_first_node (keyboard->tab_handler_list);
+                             node; node = ply_list_get_next_node (keyboard->tab_handler_list, node)) {
+                                ply_keyboard_closure_t *closure = ply_list_node_get_data (node);
